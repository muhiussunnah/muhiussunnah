# ---------------------------------------------------------------------------
# Shikkha Platform — top-level .gitignore
# (shikkha/ has its own .gitignore for the Next.js app)
# ---------------------------------------------------------------------------

# Secrets — never commit
.env
.env.*
!.env.example

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
.vscode/
.idea/

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# Build artifacts
/build/
/dist/
/.next/
/node_modules/

# Claude / local scratch
.claude/
